{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "load_type": {
      "type": "string",
      "enum": ["heavy", "medium", "light", "deload"]
    },
    "focus": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] },
    "exercises": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "exercise_id": { "type": "number" },
          "name": { "type": "string" },
          "sets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "set_index": { "type": "number" },
                "reps": { "type": "number" },
                "weight": { "type": "number" },
                "notes": { "type": ["string", "null"] }
              },
              "required": ["set_index", "reps"]
            }
          }
        },
        "required": ["exercise_id", "name", "sets"]
      }
    }
  },
  "required": ["load_type", "exercises"]
}