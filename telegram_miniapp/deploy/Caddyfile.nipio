{
	http_port 80
	https_port 8443
}

trainer.89.124.83.32.nip.io {
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}

	encode zstd gzip

	handle /api/* {
		reverse_proxy host.docker.internal:8081
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
